// ─────────────────────────────────────────────────────────────
//  SaaS CRM — Prisma Schema
//  PostgreSQL 16 with Row-Level Security for tenant isolation
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════
//  PLATFORM LEVEL (no RLS — super-admin only)
// ═══════════════════════════════════════════════════════════════

model PlatformAdmin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("platform_admins")
}

model Organization {
  id                 String    @id @default(uuid())
  name               String
  slug               String    @unique          // subdomain
  customDomain       String?   @unique
  logo               String?
  address            String?
  city               String?
  state              String?
  zipCode            String?
  country            String?
  phone              String?
  website            String?
  vatNumber          String?
  // SaaS billing
  planId             String?                    // Stripe price ID
  stripeCustomerId   String?   @unique
  stripeSubscriptionId String? @unique
  subscriptionStatus String    @default("trialing") // trialing | active | past_due | canceled | unpaid
  trialEndsAt        DateTime?
  // Settings (replaces flat tbloptions key-value table)
  settings           Json      @default("{}")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Relations
  users              User[]
  roles              Role[]
  clients            Client[]
  leads              Lead[]
  invoices           Invoice[]
  estimates          Estimate[]
  proposals          Proposal[]
  payments           Payment[]
  creditNotes        CreditNote[]
  expenses           Expense[]
  projects           Project[]
  tasks              Task[]
  tickets            Ticket[]
  contracts          Contract[]
  surveys            Survey[]
  goals              Goal[]
  announcements      Announcement[]
  currencies         Currency[]
  taxes              Tax[]
  paymentModes       PaymentMode[]
  customFields       CustomField[]
  emailTemplates     EmailTemplate[]
  knowledgeBaseGroups KnowledgeBaseGroup[]
  departments        Department[]
  leadStatuses       LeadStatus[]
  leadSources        LeadSource[]
  expenseCategories  ExpenseCategory[]
  contractTypes      ContractType[]
  clientGroups       ClientGroup[]
  events             Event[]

  @@map("organizations")
}

// ═══════════════════════════════════════════════════════════════
//  USERS & AUTH
// ═══════════════════════════════════════════════════════════════

model User {
  id             String    @id @default(uuid())
  organizationId String
  email          String
  password       String?               // null for OAuth-only users; phpass hash during migration
  passwordFormat String    @default("bcrypt") // "bcrypt" | "phpass" — transition field
  firstName      String
  lastName       String
  // "staff" | "contact" — replaces separate tblstaff / tblcontacts split
  type           String    @default("staff")
  isAdmin        Boolean   @default(false)
  active         Boolean   @default(true)
  // Staff-specific
  roleId         String?
  hourlyRate     Decimal?  @db.Decimal(10, 2)
  department     String?
  jobTitle       String?
  // Contact-specific (when type = "contact")
  clientId       String?
  isPrimary      Boolean   @default(false)
  // Profile
  avatar         String?
  phone          String?
  phoneMobile    String?
  skype          String?
  direction      String    @default("ltr")
  language       String    @default("en")
  timezone       String    @default("UTC")
  lastLogin      DateTime?
  lastIp         String?
  // 2FA
  twoFaEnabled   Boolean   @default(false)
  twoFaSecret    String?
  // OAuth
  oauthProvider  String?   // "google" | "microsoft"
  oauthId        String?
  // Email / notification prefs
  emailNotifications Boolean @default(true)
  // Timestamps
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           Role?        @relation(fields: [roleId], references: [id])
  client         Client?      @relation(fields: [clientId], references: [id])
  sessions       UserSession[]
  notifications  Notification[]
  assignedTasks  TaskAssignment[]
  timeEntries    TimeEntry[]
  activityLogs   ActivityLog[]

  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([organizationId, type])
  @@map("users")
}

model UserSession {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
}

model Role {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  // JSONB — e.g. {"invoices":{"view":true,"create":true},"clients":{"view":true}}
  permissions    Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users          User[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("roles")
}

// ═══════════════════════════════════════════════════════════════
//  CLIENTS & CONTACTS
// ═══════════════════════════════════════════════════════════════

model ClientGroup {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  createdAt      DateTime @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clients        Client[]

  @@index([organizationId])
  @@map("client_groups")
}

model Client {
  id                    String   @id @default(uuid())
  organizationId        String
  groupId               String?
  company               String
  address               String?
  city                  String?
  state                 String?
  zipCode               String?
  country               String?
  website               String?
  phone                 String?
  vat                   String?
  currencyId            String?
  defaultLanguage       String   @default("en")
  active                Boolean  @default(true)
  registrationNumber    String?
  billingStreet         String?
  billingCity           String?
  billingState          String?
  billingZip            String?
  billingCountry        String?
  shippingStreet        String?
  shippingCity          String?
  shippingState         String?
  shippingZip           String?
  shippingCountry       String?
  longitude             String?
  latitude              String?
  stripeId              String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  organization          Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  group                 ClientGroup?  @relation(fields: [groupId], references: [id])
  currency              Currency?     @relation(fields: [currencyId], references: [id])
  contacts              User[]
  invoices              Invoice[]
  estimates             Estimate[]
  proposals             Proposal[]
  projects              Project[]
  tickets               Ticket[]
  contracts             Contract[]
  payments              Payment[]
  creditNotes           CreditNote[]
  expenses              Expense[]
  subscriptions         ClientSubscription[]
  vaultEntries          VaultEntry[]
  customFieldValues     CustomFieldValue[]

  @@index([organizationId])
  @@map("clients")
}

model VaultEntry {
  id             String   @id @default(uuid())
  organizationId String
  clientId       String
  name           String
  username       String?
  password       String?  // encrypted
  url            String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("vault_entries")
}

// ═══════════════════════════════════════════════════════════════
//  CURRENCIES & FINANCIAL SETTINGS
// ═══════════════════════════════════════════════════════════════

model Currency {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  symbol         String
  symbolPlacement String  @default("before") // "before" | "after"
  decimalSeparator String @default(".")
  thousandSeparator String @default(",")
  decimalPlaces  Int      @default(2)
  isDefault      Boolean  @default(false)
  exchangeRate   Decimal  @default(1) @db.Decimal(15, 6)
  createdAt      DateTime @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clients        Client[]
  invoices       Invoice[]
  estimates      Estimate[]
  expenses       Expense[]

  @@index([organizationId])
  @@map("currencies")
}

model Tax {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  rate           Decimal  @db.Decimal(5, 2)
  createdAt      DateTime @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("taxes")
}

model PaymentMode {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  description    String?
  active         Boolean  @default(true)
  gatewayClass   String?  // "stripe" | "paypal" | "mollie" | "manual" etc.
  settings       Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoicePayments InvoicePaymentMode[]

  @@index([organizationId])
  @@map("payment_modes")
}

// ═══════════════════════════════════════════════════════════════
//  LEADS
// ═══════════════════════════════════════════════════════════════

model LeadStatus {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  color          String   @default("#6b7280")
  position       Int      @default(0)
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leads          Lead[]

  @@index([organizationId])
  @@map("lead_statuses")
}

model LeadSource {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  createdAt      DateTime @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leads          Lead[]

  @@index([organizationId])
  @@map("lead_sources")
}

model Lead {
  id             String   @id @default(uuid())
  organizationId String
  statusId       String?
  sourceId       String?
  assignedTo     String?
  name           String
  company        String?
  email          String?
  phone          String?
  website        String?
  address        String?
  city           String?
  state          String?
  country        String?
  zipCode        String?
  description    String?
  value          Decimal? @db.Decimal(15, 2)
  // Kanban position within status column
  position       Int      @default(0)
  isPublic       Boolean  @default(false)
  lostReason     String?
  convertedAt    DateTime?
  convertedToClientId String?
  lastContact    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  status         LeadStatus?  @relation(fields: [statusId], references: [id])
  source         LeadSource?  @relation(fields: [sourceId], references: [id])
  notes          LeadNote[]
  customFieldValues CustomFieldValue[]

  @@index([organizationId])
  @@index([organizationId, statusId])
  @@map("leads")
}

model LeadNote {
  id        String   @id @default(uuid())
  leadId    String
  userId    String?
  content   String
  createdAt DateTime @default(now())

  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_notes")
}

// ═══════════════════════════════════════════════════════════════
//  INVOICES
// ═══════════════════════════════════════════════════════════════

model Invoice {
  id               String   @id @default(uuid())
  organizationId   String
  clientId         String?
  currencyId       String?
  number           String   // e.g. "INV-0001"
  referenceNumber  String?
  status           String   @default("draft") // draft | unpaid | partial | paid | overdue | cancelled
  date             DateTime
  dueDate          DateTime?
  subTotal         Decimal  @db.Decimal(15, 2) @default(0)
  discount         Decimal  @db.Decimal(15, 2) @default(0)
  discountType     String   @default("fixed")  // "fixed" | "percent"
  adjustment       Decimal  @db.Decimal(15, 2) @default(0)
  total            Decimal  @db.Decimal(15, 2) @default(0)
  totalTax         Decimal  @db.Decimal(15, 2) @default(0)
  clientNote       String?
  adminNote        String?
  terms            String?
  // Allowed payment gateways for this invoice
  allowedPaymentModes String[] @default([])
  // Recurring invoice settings
  isRecurring      Boolean  @default(false)
  recurringEvery   Int?
  recurringType    String?  // "day" | "week" | "month" | "year"
  recurringFrom    String?  // null | date
  totalCycles      Int?     // null = infinite
  totalCyclesCompleted Int  @default(0)
  lastRecurringDate DateTime?
  nextRecurringDate DateTime?
  recurringFromInvoiceId String?
  // Hash for public URL access (no login needed)
  hash             String   @unique @default(uuid())
  sentAt           DateTime?
  paidAt           DateTime?
  cancelledAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client           Client?      @relation(fields: [clientId], references: [id])
  currency         Currency?    @relation(fields: [currencyId], references: [id])
  items            InvoiceItem[]
  payments         Payment[]
  creditNotes      CreditNote[]
  customFieldValues CustomFieldValue[]
  paymentAttempts  PaymentAttempt[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, clientId])
  @@map("invoices")
}

model InvoiceItem {
  id          String   @id @default(uuid())
  invoiceId   String
  description String
  longDesc    String?
  qty         Decimal  @db.Decimal(10, 2) @default(1)
  rate        Decimal  @db.Decimal(15, 2) @default(0)
  tax1        String?  // tax id
  tax2        String?  // tax id
  unit        String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

model Payment {
  id             String   @id @default(uuid())
  organizationId String
  invoiceId      String
  clientId       String?
  paymentModeId  String?
  amount         Decimal  @db.Decimal(15, 2)
  currency       String?
  transactionId  String?
  note           String?
  paymentDate    DateTime
  gatewayResponse Json?
  createdAt      DateTime @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoice        Invoice      @relation(fields: [invoiceId], references: [id])
  client         Client?      @relation(fields: [clientId], references: [id])

  @@index([organizationId])
  @@map("payments")
}

model InvoicePaymentMode {
  invoiceId     String
  paymentModeId String

  paymentMode   PaymentMode @relation(fields: [paymentModeId], references: [id])

  @@id([invoiceId, paymentModeId])
  @@map("invoice_payment_modes")
}

model PaymentAttempt {
  id          String   @id @default(uuid())
  invoiceId   String
  gateway     String
  amount      Decimal  @db.Decimal(15, 2)
  status      String   // "pending" | "success" | "failed"
  response    Json?
  createdAt   DateTime @default(now())

  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("payment_attempts")
}

model CreditNote {
  id             String   @id @default(uuid())
  organizationId String
  clientId       String?
  invoiceId      String?
  number         String
  status         String   @default("open") // open | closed | void
  date           DateTime
  subTotal       Decimal  @db.Decimal(15, 2) @default(0)
  discount       Decimal  @db.Decimal(15, 2) @default(0)
  discountType   String   @default("fixed")
  total          Decimal  @db.Decimal(15, 2) @default(0)
  totalTax       Decimal  @db.Decimal(15, 2) @default(0)
  remainingAmount Decimal @db.Decimal(15, 2) @default(0)
  clientNote     String?
  adminNote      String?
  hash           String   @unique @default(uuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client         Client?      @relation(fields: [clientId], references: [id])
  invoice        Invoice?     @relation(fields: [invoiceId], references: [id])
  items          CreditNoteItem[]

  @@index([organizationId])
  @@map("credit_notes")
}

model CreditNoteItem {
  id           String   @id @default(uuid())
  creditNoteId String
  description  String
  qty          Decimal  @db.Decimal(10, 2) @default(1)
  rate         Decimal  @db.Decimal(15, 2) @default(0)
  tax1         String?
  tax2         String?
  order        Int      @default(0)

  creditNote   CreditNote @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)

  @@map("credit_note_items")
}

// ═══════════════════════════════════════════════════════════════
//  ESTIMATES
// ═══════════════════════════════════════════════════════════════

model Estimate {
  id              String   @id @default(uuid())
  organizationId  String
  clientId        String?
  currencyId      String?
  number          String
  referenceNumber String?
  status          String   @default("draft") // draft | sent | declined | accepted | expired
  date            DateTime
  expiryDate      DateTime?
  subTotal        Decimal  @db.Decimal(15, 2) @default(0)
  discount        Decimal  @db.Decimal(15, 2) @default(0)
  discountType    String   @default("fixed")
  adjustment      Decimal  @db.Decimal(15, 2) @default(0)
  total           Decimal  @db.Decimal(15, 2) @default(0)
  totalTax        Decimal  @db.Decimal(15, 2) @default(0)
  clientNote      String?
  adminNote       String?
  terms           String?
  hash            String   @unique @default(uuid())
  sentAt          DateTime?
  acceptedAt      DateTime?
  declinedAt      DateTime?
  convertedToInvoiceId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client          Client?      @relation(fields: [clientId], references: [id])
  currency        Currency?    @relation(fields: [currencyId], references: [id])
  items           EstimateItem[]
  customFieldValues CustomFieldValue[]

  @@index([organizationId])
  @@map("estimates")
}

model EstimateItem {
  id          String   @id @default(uuid())
  estimateId  String
  description String
  longDesc    String?
  qty         Decimal  @db.Decimal(10, 2) @default(1)
  rate        Decimal  @db.Decimal(15, 2) @default(0)
  tax1        String?
  tax2        String?
  unit        String?
  order       Int      @default(0)

  estimate    Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  @@map("estimate_items")
}

// ═══════════════════════════════════════════════════════════════
//  PROPOSALS
// ═══════════════════════════════════════════════════════════════

model Proposal {
  id             String   @id @default(uuid())
  organizationId String
  clientId       String?
  relType        String?  // "lead" | "customer"
  relId          String?
  subject        String
  content        String?
  status         String   @default("draft") // draft | sent | open | revised | declined | accepted
  currency       String?
  total          Decimal? @db.Decimal(15, 2)
  discount       Decimal? @db.Decimal(15, 2)
  discountType   String?
  openTill       DateTime?
  hash           String   @unique @default(uuid())
  signature      String?  // base64 SVG/PNG
  signedAt       DateTime?
  signedName     String?
  sentAt         DateTime?
  dateCreated    DateTime
  allowComments  Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client         Client?      @relation(fields: [clientId], references: [id])
  items          ProposalItem[]
  comments       ProposalComment[]
  customFieldValues CustomFieldValue[]

  @@index([organizationId])
  @@map("proposals")
}

model ProposalItem {
  id          String   @id @default(uuid())
  proposalId  String
  description String
  longDesc    String?
  qty         Decimal  @db.Decimal(10, 2) @default(1)
  rate        Decimal  @db.Decimal(15, 2) @default(0)
  tax1        String?
  tax2        String?
  unit        String?
  order       Int      @default(0)

  proposal    Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@map("proposal_items")
}

model ProposalComment {
  id         String   @id @default(uuid())
  proposalId String
  userId     String?
  content    String
  createdAt  DateTime @default(now())

  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@map("proposal_comments")
}

// ═══════════════════════════════════════════════════════════════
//  EXPENSES
// ═══════════════════════════════════════════════════════════════

model ExpenseCategory {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  description    String?
  createdAt      DateTime @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  expenses       Expense[]

  @@index([organizationId])
  @@map("expense_categories")
}

model Expense {
  id             String   @id @default(uuid())
  organizationId String
  categoryId     String?
  clientId       String?
  projectId      String?
  currencyId     String?
  name           String
  amount         Decimal  @db.Decimal(15, 2)
  tax            String?
  tax2           String?
  date           DateTime
  paymentMode    String?
  reference      String?
  note           String?
  invoiced       Boolean  @default(false)
  invoiceId      String?
  billable       Boolean  @default(false)
  recurring      Boolean  @default(false)
  recurringType  String?
  lastRecurringDate DateTime?
  attachment     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category       ExpenseCategory? @relation(fields: [categoryId], references: [id])
  client         Client?          @relation(fields: [clientId], references: [id])
  currency       Currency?        @relation(fields: [currencyId], references: [id])
  project        Project?         @relation(fields: [projectId], references: [id])

  @@index([organizationId])
  @@map("expenses")
}

// ═══════════════════════════════════════════════════════════════
//  SUBSCRIPTIONS (per-client recurring billing)
// ═══════════════════════════════════════════════════════════════

model ClientSubscription {
  id              String   @id @default(uuid())
  organizationId  String
  clientId        String
  name            String
  description     String?
  quantity        Int      @default(1)
  unitPrice       Decimal  @db.Decimal(15, 2)
  total           Decimal  @db.Decimal(15, 2)
  status          String   @default("active") // active | cancelled | paused
  stripeSubId     String?
  nextDueDate     DateTime?
  cancelledAt     DateTime?
  hash            String   @unique @default(uuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("client_subscriptions")
}

// ═══════════════════════════════════════════════════════════════
//  PROJECTS & TASKS
// ═══════════════════════════════════════════════════════════════

model Project {
  id              String   @id @default(uuid())
  organizationId  String
  clientId        String?
  name            String
  description     String?
  status          String   @default("not_started") // not_started | in_progress | on_hold | cancelled | finished
  billingType     String   @default("fixed_cost")  // fixed_cost | project_hours | task_hours | not_billable
  fixedRate       Decimal? @db.Decimal(15, 2)
  hourlyRate      Decimal? @db.Decimal(10, 2)
  budgetNotify    Boolean  @default(false)
  progressManual  Boolean  @default(false)
  progress        Int      @default(0)
  startDate       DateTime?
  deadline        DateTime?
  estimatedHours  Decimal? @db.Decimal(10, 2)
  settings        Json     @default("{}")  // client permissions matrix
  hash            String   @unique @default(uuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client          Client?       @relation(fields: [clientId], references: [id])
  members         ProjectMember[]
  milestones      Milestone[]
  tasks           Task[]
  expenses        Expense[]
  discussions     ProjectDiscussion[]
  files           ProjectFile[]
  timeEntries     TimeEntry[]
  notes           ProjectNote[]
  customFieldValues CustomFieldValue[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@map("projects")
}

model ProjectMember {
  id             String @id @default(uuid())
  projectId      String
  userId         String
  hourlyRate     Decimal? @db.Decimal(10, 2)

  project        Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

model Milestone {
  id             String   @id @default(uuid())
  organizationId String
  projectId      String
  name           String
  description    String?
  dueDate        DateTime?
  completed      Boolean  @default(false)
  completedAt    DateTime?
  color          String   @default("#6b7280")
  order          Int      @default(0)
