  @@map("milestones")
}

model Task {
  id             String   @id @default(uuid())
  organizationId String
  projectId      String?
  milestoneId    String?
  relType        String?  // "project" | "lead" | "ticket" etc.
  relId          String?
  name           String
  description    String?
  status         String   @default("not_started") // not_started | in_progress | testing | awaiting_feedback | complete
  priority       String   @default("medium")      // low | medium | high | urgent
  startDate      DateTime?
  dueDate        DateTime?
  hourlyRate     Decimal? @db.Decimal(10, 2)
  billingType    String   @default("task_hours")
  estimatedHours Decimal? @db.Decimal(10, 2)
  order          Int      @default(0)
  isPublic       Boolean  @default(true)
  billable       Boolean  @default(false)
  createdBy      String?
  completedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project        Project?        @relation(fields: [projectId], references: [id])
  milestone      Milestone?      @relation(fields: [milestoneId], references: [id])
  assignments    TaskAssignment[]
  checklists     TaskChecklist[]
  comments       TaskComment[]
  attachments    TaskAttachment[]
  timeEntries    TimeEntry[]
  customFieldValues CustomFieldValue[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, projectId])
  @@map("tasks")
}

model TaskAssignment {
  taskId String
  userId String

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

