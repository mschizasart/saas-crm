// ═══════════════════════════════════════════════════════════════
//  CUSTOM FIELDS (polymorphic)
// ═══════════════════════════════════════════════════════════════

model CustomField {
  id             String   @id @default(uuid())
  organizationId String
  // "client" | "contact" | "invoice" | "estimate" | "proposal" | "expense"
  // | "project" | "task" | "ticket" | "lead" | "contract"
  fieldTo        String
  name           String
  slug           String
  type           String   // "text" | "textarea" | "select" | "number" | "date" | "checkbox" | "url" | "email"
  options        String[] @default([]) // for select type
  defaultValue   String?
  placeholder    String?
  required       Boolean  @default(false)
  showOnTable    Boolean  @default(false)
  showOnPdf      Boolean  @default(false)
  showOnPortal   Boolean  @default(false)
  order          Int      @default(0)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  values         CustomFieldValue[]

  @@index([organizationId, fieldTo])
  @@map("custom_fields")
}

model CustomFieldValue {
  id             String   @id @default(uuid())
  organizationId String
  fieldId        String
  // Polymorphic target
  relType        String   // matches CustomField.fieldTo
  relId          String
  value          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  field          CustomField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  // Polymorphic — optional relations for type checking only
  client         Client?   @relation(fields: [relId], references: [id], map: "cfv_client")
  invoice        Invoice?  @relation(fields: [relId], references: [id], map: "cfv_invoice")
  estimate       Estimate? @relation(fields: [relId], references: [id], map: "cfv_estimate")
  proposal       Proposal? @relation(fields: [relId], references: [id], map: "cfv_proposal")
  lead           Lead?     @relation(fields: [relId], references: [id], map: "cfv_lead")
  project        Project?  @relation(fields: [relId], references: [id], map: "cfv_project")
  task           Task?     @relation(fields: [relId], references: [id], map: "cfv_task")
  ticket         Ticket?   @relation(fields: [relId], references: [id], map: "cfv_ticket")
  contract       Contract? @relation(fields: [relId], references: [id], map: "cfv_contract")

  @@unique([fieldId, relId])
  @@index([organizationId, relType, relId])
  @@map("custom_field_values")
}

// ═══════════════════════════════════════════════════════════════
//  NOTIFICATIONS & ACTIVITY
// ═══════════════════════════════════════════════════════════════

model Notification {
  id             String   @id @default(uuid())
  organizationId String
  userId         String
  fromUserId     String?
  title          String
  description    String?
  // "invoice" | "task" | "ticket" | "project" | "lead" | "contract" | "estimate" | "proposal"
  type           String?
  relId          String?
  link           String?
  read           Boolean  @default(false)
  readAt         DateTime?
  createdAt      DateTime @default(now())

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId])
  @@map("notifications")
}

model ActivityLog {
  id             String   @id @default(uuid())
  organizationId String
  userId         String?
  // e.g. "invoice_added", "client_updated", "ticket_replied"
  action         String
  relType        String?
  relId          String?
  description    String?
  additionalData Json?
  ipAddress      String?
  createdAt      DateTime @default(now())

  user           User?    @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([organizationId, relType, relId])
  @@map("activity_log")
}

