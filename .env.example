# ─── Database ────────────────────────────────────────────────
DATABASE_URL="postgresql://crm:devpassword@localhost:5432/saascrm"

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── MinIO ───────────────────────────────────────────────────
MINIO_ENDPOINT="http://localhost:9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="saas-crm"

# ─── Auth ────────────────────────────────────────────────────
JWT_SECRET="change-me-in-production-minimum-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-minimum-32-chars"
JWT_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# ─── OAuth ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_TENANT_ID="common"

# ─── Stripe (SaaS billing — charging tenants) ────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_STARTER="price_..."
STRIPE_PRICE_GROWTH="price_..."
STRIPE_PRICE_PROFESSIONAL="price_..."

# ─── Email (SMTP) ────────────────────────────────────────────
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@yoursaas.com"

# ─── OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY=""

# ─── App ─────────────────────────────────────────────────────
APP_URL="http://localhost:3000"
API_URL="http://localhost:3001"
NODE_ENV="development"

# ─── Next.js (prefix with NEXT_PUBLIC_ for browser access) ──
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-nextauth-secret"
